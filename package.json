{
  "name": "location_api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "cross-env NODE_ENV=production node build/server.js",
    "start-dev": "NODE_ENV=development node build/server.js",
    "dev": "ts-node-dev --transpile-only --ignore-watch node_modules --respawn src/server.ts",
    "migration:generate": "ts-node ./node_modules/typeorm/cli.js migration:create",
    "migration-prod:run": "NODE_ENV=production ts-node ./node_modules/typeorm/cli.js migration:run -d ./src/Infra/Database/connection.ts",
    "migration:run": "NODE_ENV=developement ts-node ./node_modules/typeorm/cli.js migration:run -d ./src/Infra/Database/connection.ts",
    "migration:revert": "ts-node ./node_modules/typeorm/cli.js migration:revert -d /src/Infra/Database/connection.ts",
    "build": "cross-env NODE_ENV=developement rm -rf build && npx tsc",
    "build-prod": "NODE_ENV=production rm -rf build && npx tsc"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "country-state-city": "^3.2.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-fileupload": "^1.4.1",
    "jest": "^29.5.0",
    "morgan": "^1.10.0",
    "node-geocoder": "^4.3.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "yamljs": "^0.3.0",
    "zipcodes": "^8.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/express-fileupload": "^1.4.3",
    "@types/jest": "^29.5.1",
    "@types/node-geocoder": "^4.2.6",
    "@types/supertest": "^2.0.15",
    "@types/yamljs": "^0.2.33",
    "@types/zipcodes": "^8.0.5",
    "cross-env": "^10.1.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.5.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  }
}
